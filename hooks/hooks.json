{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/skills/git-discipline/scripts/git-guard.js\""
          }
        ],
        "description": "git-discipline: enforce conventional commits, no Co-Authored-By, --no-ff merges, no branch deletion, no force-adding ignored files",
        "id": "git-discipline:pre-bash"
      }
    ]
  }
}
